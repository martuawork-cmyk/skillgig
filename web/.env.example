# SkillGig.id — Supabase environment variables
# Copy this file to `.env.local` and fill in your real values.
# Get these from your Supabase project dashboard:
#   https://app.supabase.com/project/<your-project>/settings/api

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anon (public) key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key

# Supabase service-role key — bypasses RLS, FULL table access. SERVER-ONLY:
# never prefix with NEXT_PUBLIC_, never commit the real value. Without this,
# every /admin page renders "Admin belum tersedia" and admin queries 500.
# Get it from Supabase Settings → API → "service_role".
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key

# Canonical public site URL used for SEO metadata, OG tags, and the sitemap.
# Optional — defaults to https://skillgig.id when unset.
NEXT_PUBLIC_SITE_URL=https://skillgig.id

# ----- Newsletter (P2-A) ---------------------------------------------------
# Optional. When unset, /api/subscribe still works but skips sending the
# welcome email (the row is still saved). Get a key at:
#   https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Optional. Defaults to "SkillGig <hello@skillgig.id>". Must be a verified
# sender in your Resend dashboard.
RESEND_FROM_EMAIL=SkillGig <hello@skillgig.id>

# ----- Remotive auto-sync (Task B5 / C3) ------------------------------------
# Shared secret protecting /api/cron/fetch-jobs (and the /api/cron/sync-jobs
# alias). Vercel Cron injects it as the `Authorization: Bearer <CRON_SECRET>`
# header automatically (it reads this var from the project env). Set it in the
# Vercel dashboard → Settings → Environment Variables with the SAME name.
# Generate one with, e.g.:
#   openssl rand -hex 32
CRON_SECRET=your_secret_here

# ----- Telegram approval notifications (Task C3) ---------------------------
# Optional. When BOTH are set, approving a gig (status → 'published') pings the
# Telegram channel/group via the Bot API. When unset, the notification is a
# silent no-op (the approve flow still works). Create a bot with @BotFather to
# get the token; the chat id is the target channel/group (e.g. -1001234567890).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ----- FX rate overrides (Task C3) -----------------------------------------
# Optional. lib/currency.ts converts USD/EUR salaries to IDR using a static
# fallback rate. Override either here (server env) to pin a fresher rate:
#   FX_USD_TO_IDR=16450
#   FX_EUR_TO_IDR=17800

# ----- PostHog product analytics -------------------------------------------
# Optional. When NEXT_PUBLIC_POSTHOG_KEY is set, the AnalyticsProvider
# (components/analytics/PostHogProvider) initialises PostHog on the client and
# `track()` (lib/analytics.ts) fires events: gig_apply_clicked,
# course_start_clicked, job_saved. When unset, tracking is a silent no-op and
# the provider renders children untouched — local dev / CI stay quiet.
# Get a project key + host from your PostHog project settings:
#   https://us.posthog.com  (or https://eu.posthog.com)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com